// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node
{
	"name": "Node.js",
	"image": "mcr.microsoft.com/devcontainers/javascript-node",
	"remoteEnv": {
		// Use polling to detect file changes in the container. Applies to Vite dev server.
		"CHOKIDAR_USEPOLLING": "true",
		// Poll for file changes every second (1000 ms) instead of the default 100 ms. Reduces CPU usage.
		"CHOKIDAR_INTERVAL": "1000"
	},
	"mounts": [
		// mounts the node_modules folder as a volume to prevent host and container node_modules from conflicting with each other
		"type=volume,source=node_modules_cache,target=${containerWorkspaceFolder}/node_modules/"
	],
	"postCreateCommand": "sudo chown node:node node_modules -R"
}
